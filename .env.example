# Hugging Face token (neu dung model private)
HF_TOKEN=

# Gemini API key (neu dung evaluators)
GEMINI_API_KEY=

# Duong dan du lieu va storage
DATA_DIR=./data/generative_ai
CHROMA_DIR=./storage/chroma
ARTIFACTS_DIR=./artifacts
SPLIT_DOCS_PATH=./artifacts/split_documents.txt

# Model configs
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
LLM_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKING=true

# LLM generation
LLM_TEMPERATURE=0.2
LLM_MAX_NEW_TOKENS=450
LLM_TOP_P=0.75

# Text splitting + retrieval
CHUNK_SIZE=400
CHUNK_OVERLAP=120
RETRIEVER_K=3

# Ingest
INGEST_FILE_TYPES=pdf,txt,md,docx,xlsx
INGEST_TABLES=true
TABLE_ROWS_PER_CHUNK=8
FEE_FACT_CHUNKING=true
FEE_FACT_PATTERNS=bieu_phi,bieu-phi,fee
FEE_FACT_INCLUDE_RAW_TEXT=true
